{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 5,
  "ignorePaths": ["Dockerfile"],
  "packageRules": [
    {
      "description": "Respect the version ranges written in Cargo.toml: update Cargo.lock only, leaving e.g. `tokio = \"1\"` untouched. A major (out of range) still edits the manifest, since it must.",
      "matchManagers": ["cargo"],
      "rangeStrategy": "update-lockfile"
    },
    {
      "description": "Batch routine crate updates into one weekly PR; majors stay separate.",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "rust crates (non-major)"
    },
    {
      "description": "Group GitHub Actions bumps together.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the trunk version pinned in the Containerfile and container.yml current.",
      "fileMatch": ["(^|/)Containerfile$", "^\\.github/workflows/container\\.yml$"],
      "matchStrings": ["TRUNK_VERSION[=:]\\s*\"?(?<currentValue>[0-9][0-9.]*)\"?"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "trunk-rs/trunk",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ]
}
