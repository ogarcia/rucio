# Build artifacts — largest exclusion, speeds up context transfer significantly
target/

# Pre-built binaries injected by CI (not present in local builds)
# dist/ is intentionally NOT excluded — it must be available when
# building with --build-arg BUILDER=prebuilt
# Tests — not needed inside the container build
tests/

# Git and CI metadata
.git/
.github/
.githooks/

# Editor and OS noise
.vscode/
.idea/
*.swp
*~
.DS_Store

# Docs and specs
SPEC.md
*.md

# Redundant symlink — we reference Containerfile explicitly in CI
Dockerfile
