# Single source of truth for build-tool and base-image versions.
#
# Consumers:
#   - Containerfile keeps matching ARG defaults (so a local `podman build .`
#     works offline); CI overrides them from this file via --build-arg.
#   - The GitHub workflows load these into $GITHUB_ENV (a "Load build versions"
#     step) and use them to pin trunk and pass the container build args.
#
# Keep the Containerfile ARG defaults equal to the values here.
ALPINE_VERSION=3.23
RUST_VERSION=1
TRUNK_VERSION=0.21.14
